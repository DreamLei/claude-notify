{
  "mcpServers": {
    "ask-dialog": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/mcp/ask-dialog-server.js"
      ],
      "env": {
        "WEBHOOK_URL": "${user_config.webhook_url}",
        "MENTION": "${user_config.mention}",
        "NOTIFY_ENABLED": "${user_config.enable_notifications}",
        "SMART_SWITCH": "${user_config.smart_switch}",
        "WECHAT_PUSH_ENABLED": "${user_config.enable_wechat_push}"
      },
      "alwaysLoad": true
    }
  }
}