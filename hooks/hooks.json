{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "NOTIFY_ENABLED=\"${user_config.enable_notifications}\" \"${CLAUDE_PLUGIN_ROOT}\"/hooks/notify-done.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "NOTIFY_ENABLED=\"${user_config.enable_notifications}\" \"${CLAUDE_PLUGIN_ROOT}\"/hooks/notify-wait.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/mark-activity.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/permission-gate.sh \"${user_config.enable_permission_gate}\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
